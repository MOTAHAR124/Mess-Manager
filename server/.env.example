# ==========================================
# DATABASE CONFIGURATION
# ==========================================
DATABASE_URL=postgresql://meso_user:meso_password@localhost:5432/meso_db
DATABASE_LOG=query,error,warn

# ==========================================
# JWT AUTHENTICATION
# ==========================================
JWT_SECRET=your_super_secret_jwt_key_min_32_characters_change_in_prod
JWT_REFRESH_SECRET=your_refresh_secret_min_32_characters_change_in_prod
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ==========================================
# GOOGLE OAUTH 2.0
# ==========================================
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/v1/auth/google/callback

# ==========================================
# SERVER CONFIGURATION
# ==========================================
NODE_ENV=development
PORT=3001
API_PREFIX=api/v1
FRONTEND_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# Optional: user id that bypasses normal role checks as admin.
ADMIN_USER_ID=
